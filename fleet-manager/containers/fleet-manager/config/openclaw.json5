{
  secrets: {
    providers: {
      container: {
        source: "file",
        path: "/run/secrets",
        mode: "dir",
      },
      env: {
        source: "env",
      },
    },
  },

  gateway: {
    mode: "local",
    port: 18799,
    bind: "lan",
    auth: {
      mode: "token",
      token: { "$secret": "container:GATEWAY_AUTH_TOKEN" },
    },
  },

  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
      userTimezone: "America/New_York",

      models: {
        "anthropic/claude-opus-4-5": { alias: "opus" },
        "anthropic/claude-sonnet-4": { alias: "sonnet" },
        "openai/gpt-5.3": { alias: "gpt" },
      },

      model: {
        primary: "anthropic/claude-opus-4-5",
        fallbacks: ["openai/gpt-5.3"],
      },

      thinkingDefault: "adaptive",
      maxConcurrent: 4,
      timeoutSeconds: 900,
    },

    list: [
      {
        id: "main",
        default: true,
        name: "Fleet Manager",
        workspace: "/home/node/.openclaw/workspace",
        model: "anthropic/claude-opus-4-5",
        params: {
          thinkingDefault: "adaptive",
        },
        subagents: { allowAgents: ["*"] },
      },
    ],
  },

  bindings: [],

  tools: {
    profile: "coding",
    sessions: { visibility: "tree" },
    exec: {
      security: "full",
      ask: "off",
      backgroundMs: 15000,
      timeoutSec: 3600,
      notifyOnExit: true,
    },
    elevated: {
      enabled: false,
    },
    subagents: {
      tools: {
        deny: ["gateway", "cron", "browser", "canvas", "nodes", "message"],
      },
    },
  },

  cron: {
    enabled: true,
    maxConcurrentRuns: 1,
    sessionRetention: "48h",
  },

  acp: {
    enabled: true,
    backend: "acpx",
    defaultAgent: "codex",
    allowedAgents: ["codex", "claude", "pi", "opencode", "gemini"],
    maxConcurrentSessions: 4,
    runtime: {
      ttlMinutes: 120,
    },
  },

  skills: {
    entries: {
      "coding-agent": { enabled: true },
      github: { enabled: true },
      "fleet-manager": { enabled: true },
    },
  },

  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "pretty",
  },
}
