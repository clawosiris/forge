// ═══════════════════════════════════════════════════════════════════════════
// Multi-Agent Engineering Process — Addon Config (v2)
// ═══════════════════════════════════════════════════════════════════════════
//
// MERGE these sections into your EXISTING openclaw.json.
// This is NOT a standalone config — it shows only what to add/change.
//
// Lines marked [ADD] are new sections.
// Lines marked [MERGE] should be merged into existing sections.
// ═══════════════════════════════════════════════════════════════════════════
{
  // [MERGE] into agents.defaults
  agents: {
    defaults: {
      // [ADD] if not present — model catalog for engineering agents
      models: {
        "anthropic/claude-opus-4-5":   { alias: "opus" },
        "anthropic/claude-opus-4-6":   { alias: "opus46" },
        "anthropic/claude-sonnet-4":   { alias: "sonnet" },
        "anthropic/claude-haiku-4-5":  { alias: "haiku" },
        "openai/gpt-5.3":              { alias: "gpt" },
        "openai/gpt-5-mini":           { alias: "gpt-mini" },
      },

      // [ADD] thinking level — adaptive scales with task complexity
      // Options: "off" | "low" | "medium" | "high" | "adaptive"
      // Adaptive: quick on routine messages, deep on architecture/reviews
      thinkingDefault: "adaptive",

      // [ADD] sub-agent settings for engineering workflow
      subagents: {
        model: "anthropic/claude-sonnet-4",
        maxConcurrent: 4,        // supervisor + 3 parallel specialists
        runTimeoutSeconds: 1800,
        archiveAfterMinutes: 120,
      },

      // [MERGE] increase if your current value is lower
      maxConcurrent: 4,
    },

    // [MERGE] into your existing agents.list entry
    list: [
      {
        id: "main",  // ← match your existing agent id
        // [ADD] thinking level at agent level
        params: {
          thinkingDefault: "adaptive",
        },
        // [ADD] allow spawning sub-agents
        subagents: { allowAgents: ["*"] },
      },
    ],
  },

  // [MERGE] into tools
  tools: {
    // [ADD] restrict sub-agent tools
    subagents: {
      tools: {
        deny: ["gateway", "cron", "browser", "canvas", "nodes", "message"],
      },
    },

    // [ADD] sandbox exec restrictions with safe bins for coding
    sandbox: {
      tools: {
        allow: [
          "exec", "process", "read", "write", "edit", "apply_patch",
          "sessions_list", "sessions_history", "sessions_send",
          "sessions_spawn", "session_status",
          "memory_search", "memory_get",
        ],
        deny: ["browser", "canvas", "nodes", "cron", "gateway", "message"],
      },
      exec: {
        security: "allowlist",
        safeBins: [
          // Text processing
          "head", "tail", "grep", "sed", "awk", "sort", "uniq", "wc", "tr", "cut",
          // File operations
          "ls", "find", "mkdir", "cp", "mv", "rm", "basename", "dirname", "xargs",
          "touch", "chmod", "cat", "tee",
          // Development tools
          "git", "gh", "jq", "curl",
          // Build tools
          "make", "cargo", "rustc", "python3", "pip", "node", "npm", "npx",
          // Utilities
          "date", "sleep", "echo", "printf", "mktemp", "realpath", "test", "which",
          // Coding agents
          "codex",
        ],
      },
    },

    // [ADD] if not present
    sessions: { visibility: "tree" },

    // [MERGE] increase timeouts for long builds
    exec: {
      backgroundMs: 15000,
      timeoutSec: 3600,
      notifyOnExit: true,
    },
  },

  // [ADD] ACP for spawning coding agents
  acp: {
    enabled: true,
    backend: "acpx",
    defaultAgent: "codex",
    allowedAgents: ["codex", "claude", "pi", "opencode", "gemini"],
    maxConcurrentSessions: 4,
    runtime: {
      ttlMinutes: 120,
    },
  },

  // [ADD] if not present — for future automated triage
  cron: {
    enabled: true,
    maxConcurrentRuns: 1,
    sessionRetention: "48h",
  },

  // [ADD] skills the implementer agent may use
  skills: {
    entries: {
      "coding-agent": { enabled: true },
      github: { enabled: true },
    },
  },
}
