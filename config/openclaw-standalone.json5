// ═══════════════════════════════════════════════════════════════════════════
// Forge — Multi-Agent Engineering Process
// Standalone OpenClaw Configuration with Container Sandboxing
// ═══════════════════════════════════════════════════════════════════════════
//
// Deploy with: ./deploy.sh
// Or copy this to ~/.openclaw/openclaw.json and adjust placeholder values.
// ═══════════════════════════════════════════════════════════════════════════
{
  // ─── Secrets ─────────────────────────────────────────────────────────────
  // Secrets are resolved at runtime and NOT exposed to agent context.
  // Use SecretRef syntax: { "$secret": "provider:key" } or { "$secret": "key" }
  // Run `openclaw secrets configure` for interactive setup.
  // Run `openclaw secrets audit` to find plaintext secrets.
  secrets: {
    providers: {
      // File-based secrets (default)
      local: {
        source: "file",
        path: "~/.openclaw/secrets.json",
        mode: "json",
      },
      // Environment variables (fallback)
      env: {
        source: "env",
      },
      // 1Password (optional — uncomment if using)
      // op: {
      //   source: "1password",
      //   account: "my.1password.com",
      //   vault: "OpenClaw",
      // },
    },
  },

  // ─── Environment ───────────────────────────────────────────────────────
  // Prefer secrets.providers over env for sensitive values.
  // These are for non-sensitive runtime settings only.
  env: {
    // NODE_ENV: "production",
  },

  // ─── Gateway ───────────────────────────────────────────────────────────
  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
    auth: {
      mode: "token",
      // SecretRef: resolved at runtime, not exposed to agents
      token: { "$secret": "local:GATEWAY_AUTH_TOKEN" },
    },
  },

  // ─── Agents ────────────────────────────────────────────────────────────
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      userTimezone: "America/New_York",  // ← adjust

      models: {
        "anthropic/claude-opus-4-5":   { alias: "opus" },
        "anthropic/claude-opus-4-6":   { alias: "opus46" },
        "anthropic/claude-sonnet-4":   { alias: "sonnet" },
        "anthropic/claude-haiku-4-5":  { alias: "haiku" },
        "openai/gpt-5.3":              { alias: "gpt" },
        "openai/gpt-5-mini":           { alias: "gpt-mini" },
      },

      model: {
        primary: "anthropic/claude-opus-4-5",
        fallbacks: ["openai/gpt-5.3"],
      },

      imageModel: { primary: "anthropic/claude-sonnet-4" },
      pdfModel:   { primary: "anthropic/claude-sonnet-4" },

      subagents: {
        model: "anthropic/claude-sonnet-4",
        maxConcurrent: 4,
        runTimeoutSeconds: 1800,
        archiveAfterMinutes: 120,
      },

      maxConcurrent: 4,
      timeoutSeconds: 900,
      contextTokens: 200000,

      // ── Thinking ──
      // Adaptive scales reasoning depth based on task complexity.
      // Quick responses for routine messages, deeper analysis for architecture/reviews.
      // Options: "off" | "low" | "medium" | "high" | "adaptive"
      thinkingDefault: "adaptive",

      compaction: {
        mode: "safeguard",
        reserveTokensFloor: 30000,
        memoryFlush: { enabled: true },
      },

      heartbeat: {
        every: "30m",
        model: "anthropic/claude-haiku-4-5",
        lightContext: true,
      },

      // ── Container Sandboxing ──
      // Sub-agents run inside Docker containers for isolation.
      sandbox: {
        mode: "non-main",       // sandbox sub-agents, not the main agent
        scope: "agent",         // one container per agent
        docker: {
          image: "openclaw-sandbox:bookworm-slim",
          containerPrefix: "forge-sbx-",
          workdir: "/workspace",
          readOnlyRoot: true,
          network: "bridge",    // sub-agents need network for git, tests
          user: "1000:1000",
          capDrop: ["ALL"],
          tmpfs: ["/tmp", "/var/tmp", "/run"],
          env: { LANG: "C.UTF-8" },
          setupCommand: "apt-get update && apt-get install -y git curl jq build-essential python3 python3-pip nodejs npm",
          pidsLimit: 256,
          memory: "2g",
          memorySwap: "4g",
          cpus: 2,
        },
        prune: {
          idleHours: 24,
          maxAgeDays: 7,
        },
      },
    },

    list: [
      {
        id: "main",
        default: true,
        name: "Assistant",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-opus-4-5",
        params: {
          thinkingDefault: "adaptive",
        },
        subagents: { allowAgents: ["*"] },
        // Main agent runs on host (not sandboxed)
        sandbox: { mode: "off" },
      },
    ],
  },

  // ─── Bindings ──────────────────────────────────────────────────────────
  bindings: [
    { agentId: "main", match: { channel: "signal" } },
    // { agentId: "main", match: { channel: "telegram" } },
    // { agentId: "main", match: { channel: "discord" } },
  ],

  // ─── Channels ──────────────────────────────────────────────────────────
  channels: {
    signal: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: [
        "+1XXXXXXXXXX",   // ← replace with your number
      ],
    },
    // telegram: {
    //   enabled: true,
    //   botToken: "${TELEGRAM_BOT_TOKEN}",
    //   dmPolicy: "allowlist",
    //   allowFrom: ["tg:XXXXXXXXX"],
    // },
    // discord: {
    //   enabled: true,
    //   token: "${DISCORD_BOT_TOKEN}",
    //   dmPolicy: "allowlist",
    //   threadBindings: { enabled: true, spawnSubagentSessions: true },
    //   guilds: {
    //     "GUILD_ID": {
    //       channels: {
    //         "engineering": { allow: true, requireMention: false },
    //       },
    //     },
    //   },
    // },
  },

  // ─── Tools ─────────────────────────────────────────────────────────────
  tools: {
    profile: "coding",
    sessions: { visibility: "tree" },

    exec: {
      security: "full",        // "full" for main agent, "allowlist" for sandboxed
      ask: "off",
      backgroundMs: 15000,
      timeoutSec: 3600,
      notifyOnExit: true,
      safeBinTrustedDirs: [
        "/usr/local/bin",
        "/usr/bin",
        "~/.local/bin",
        "~/.npm-global/bin",
      ],
    },

    elevated: {
      enabled: true,
      allowFrom: {
        signal: ["+1XXXXXXXXXX"],   // ← same as channels allowFrom
      },
    },

    // Sub-agents: coding tools only, no control plane access
    subagents: {
      tools: {
        deny: ["gateway", "cron", "browser", "canvas", "nodes", "message"],
      },
    },

    // Sandbox tool restrictions for sandboxed sessions
    sandbox: {
      tools: {
        allow: [
          "exec", "process", "read", "write", "edit", "apply_patch",
          "sessions_list", "sessions_history", "sessions_send",
          "sessions_spawn", "session_status",
          "memory_search", "memory_get",
        ],
        deny: ["browser", "canvas", "nodes", "cron", "gateway", "message"],
      },
      // Sandboxed agents use allowlist exec with safe bins
      exec: {
        security: "allowlist",
        safeBins: [
          // Text processing
          "head", "tail", "grep", "sed", "awk", "sort", "uniq", "wc", "tr", "cut",
          // File operations
          "ls", "find", "mkdir", "cp", "mv", "rm", "basename", "dirname", "xargs",
          "touch", "chmod", "cat", "tee",
          // Development tools
          "git", "gh", "jq", "curl",
          // Build tools
          "make", "cargo", "rustc", "python3", "pip", "node", "npm", "npx",
          // Utilities
          "date", "sleep", "echo", "printf", "mktemp", "realpath", "test", "which",
          // Coding agents
          "codex",
        ],
      },
    },
  },

  // ─── Session ───────────────────────────────────────────────────────────
  session: {
    reset: { mode: "idle", idleMinutes: 480 },
    threadBindings: { enabled: true, idleHours: 48 },
  },

  // ─── Messages ──────────────────────────────────────────────────────────
  messages: {
    queue: { mode: "collect", debounceMs: 2000, cap: 10 },
    inbound: { debounceMs: 3000 },
  },

  // ─── Cron ──────────────────────────────────────────────────────────────
  cron: {
    enabled: true,
    maxConcurrentRuns: 1,
    sessionRetention: "48h",
  },

  // ─── ACP (Agent Communication Protocol) ────────────────────────────────
  // Enable ACP for spawning coding agents via sessions_spawn
  acp: {
    enabled: true,
    backend: "acpx",
    defaultAgent: "codex",
    allowedAgents: ["codex", "claude", "pi", "opencode", "gemini"],
    maxConcurrentSessions: 4,
    stream: {
      coalesceIdleMs: 300,
      maxChunkChars: 1200,
    },
    runtime: {
      ttlMinutes: 120,
    },
  },

  // ─── Skills ────────────────────────────────────────────────────────────
  skills: {
    entries: {
      "coding-agent": { enabled: true },
      github: { enabled: true },
    },
  },

  // ─── Logging ───────────────────────────────────────────────────────────
  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "pretty",
  },
}
