{
  secrets: {
    providers: {
      container: {
        source: "file",
        path: "/run/secrets",
        mode: "dir",
      },
      env: {
        source: "env",
      },
    },
  },

  gateway: {
    mode: "local",
    port: {{ fleet_manager_port }},
    bind: "0.0.0.0",
    auth: {
      mode: "token",
      token: { "$secret": "container:GATEWAY_AUTH_TOKEN" },
    },
  },

  agents: {
    defaults: {
      workspace: "/home/openclaw/.openclaw/workspace",
      userTimezone: "America/New_York",
      model: {
        primary: "{{ fleet_manager_model }}",
        fallbacks: ["openai/gpt-5.3"],
      },
      thinkingDefault: "{{ fleet_manager_thinking }}",
      maxConcurrent: 4,
      timeoutSeconds: 900,
    },
    list: [
      {
        id: "main",
        default: true,
        name: "Fleet Manager",
        workspace: "/home/openclaw/.openclaw/workspace",
        model: "{{ fleet_manager_model }}",
      },
    ],
  },

  skills: {
    entries: {
      "fleet-manager": { enabled: true },
      github: { enabled: true },
      "coding-agent": { enabled: true },
    },
  },

  tools: {
    profile: "coding",
    sessions: { visibility: "tree" },
    exec: {
      security: "full",
      ask: "off",
      backgroundMs: 15000,
      timeoutSec: 3600,
      notifyOnExit: true,
    },
  },
}
